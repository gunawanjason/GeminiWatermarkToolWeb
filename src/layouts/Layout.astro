---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Remove Gemini AI watermarks from images using reverse alpha blending.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-0VYTHHEH0J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0VYTHHEH0J', {
        send_page_view: true,
        page_title: document.title,
        page_location: window.location.href,
        custom_map: {
          'dimension1': 'processing_duration_ms',
          'dimension2': 'file_count',
          'dimension3': 'error_type'
        }
      });

      // Track SPA navigation for Astro View Transitions
      document.addEventListener('astro:page-load', function() {
        gtag('event', 'page_view', {
          page_title: document.title,
          page_location: window.location.href,
          page_path: window.location.pathname
        });
      });
    </script>

    <ClientRouter />
  </head>
  <body
    class="min-h-screen flex flex-col bg-background font-sans antialiased text-foreground"
    transition:animate="none"
  >
    <Header />
    <main class="flex-1 w-full max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
