---
import { Layers, Clock, ImageIcon } from "lucide-react";

const navItems = [
  { href: "/", label: "Single", icon: ImageIcon },
  { href: "/batch", label: "Batch", icon: Layers },
  { href: "/history", label: "History", icon: Clock },
];

const { pathname } = Astro.url;
---

<header
  role="banner"
  class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/90 backdrop-blur-xl supports-[backdrop-filter]:bg-background/70"
>
  <div class="max-w-6xl mx-auto flex h-16 items-center justify-between px-4 sm:px-6">
    <a
      href="/"
      class="flex items-center gap-3 group transition-opacity hover:opacity-80"
    >
      <div
        class="w-10 h-10 rounded-xl flex items-center justify-center shadow-md shadow-primary/20 group-hover:shadow-primary/30 transition-shadow"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 32 32"
          fill="none"
          class="w-6 h-6"
        >
          <circle cx="16" cy="16" r="14" fill="#6B9080"/>
          <circle cx="16" cy="16" r="8" fill="#FAF9F6"/>
          <path d="M16 8 L19 14 L16 12 L13 14 Z" fill="#6B9080"/>
          <path d="M16 24 L13 18 L16 20 L19 18 Z" fill="#6B9080"/>
          <path d="M8 16 L14 13 L12 16 L14 19 Z" fill="#6B9080"/>
          <path d="M24 16 L18 19 L20 16 L18 13 Z" fill="#6B9080"/>
        </svg>
      </div>
      <div class="flex flex-col items-start">
        <span class="font-heading font-semibold text-base sm:text-lg text-foreground tracking-tight">
          Gemini Remover
        </span>
        <span
          class="text-[10px] font-medium text-primary/80 tracking-wide uppercase"
        >
          Private & Local
        </span>
      </div>
    </a>

    <nav
      role="navigation"
      aria-label="Main navigation"
      class="flex items-center gap-1 sm:gap-2"
    >
      {
        navItems.map(({ href, label, icon: Icon }) => {
          const isActive =
            pathname === href || (href !== "/" && pathname.startsWith(href));
          const tabName = href === "/" ? "single" : href === "/batch" ? "batch" : "history";
          return (
            <a
              href={href}
              data-tab-name={tabName}
              onclick={`if (typeof gtag !== 'undefined') { gtag('event', 'tab_switch', { tab_name: '${tabName}' }); }`}
              class:list={[
                "flex items-center gap-2 px-3 sm:px-4 py-2 rounded-xl text-sm font-medium transition-all duration-250",
                "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2",
                isActive
                  ? "bg-primary text-primary-foreground shadow-md"
                  : "text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
            >
              <Icon className="w-4 h-4" />
              <span class="hidden sm:inline">{label}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
