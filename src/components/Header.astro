---
import { Layers, Clock, ImageIcon } from "lucide-react";

const navItems = [
  { href: "/", label: "Single", icon: ImageIcon },
  { href: "/batch", label: "Batch", icon: Layers },
  { href: "/history", label: "History", icon: Clock },
];

const { pathname } = Astro.url;
---

<header
  role="banner"
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60"
>
  <div class="max-w-5xl mx-auto flex h-16 items-center justify-between px-4">
    <a
      href="/"
      class="flex items-center gap-2 group transition-opacity hover:opacity-80"
    >
      <div
        class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 32 32"
          fill="none"
          class="w-6 h-6"
        >
          <circle cx="16" cy="16" r="14" class="fill-primary"></circle>
          <circle cx="16" cy="16" r="8" class="fill-background"></circle>
          <path d="M16 8 L19 14 L16 12 L13 14 Z" class="fill-primary"></path>
          <path d="M16 24 L13 18 L16 20 L19 18 Z" class="fill-primary"></path>
          <path d="M8 16 L14 13 L12 16 L14 19 Z" class="fill-primary"></path>
          <path d="M24 16 L18 19 L20 16 L18 13 Z" class="fill-primary"></path>
        </svg>
      </div>
      <div
        class="flex flex-col items-start sm:flex-row sm:items-center gap-0.5 sm:gap-2"
      >
        <span
          class="font-bold text-base sm:text-lg text-foreground tracking-tight"
          >Gemini Watermark Remover</span
        >
        <span
          class="bg-muted/50 text-muted-foreground text-[10px] font-medium px-1.5 py-0.5 rounded-full border border-border/40 whitespace-nowrap leading-none"
        >
          100% Client Side
        </span>
      </div>
    </a>

    <nav role="navigation" aria-label="Main navigation" class="flex items-center gap-1">
      {
        navItems.map(({ href, label, icon: Icon }) => {
          const isActive =
            pathname === href || (href !== "/" && pathname.startsWith(href));
          const tabName = href === "/" ? "single" : href === "/batch" ? "batch" : "history";
          return (
            <a
              href={href}
              data-tab-name={tabName}
              onclick={`if (typeof gtag !== 'undefined') { gtag('event', 'tab_switch', { tab_name: '${tabName}' }); }`}
              class:list={[
                "flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium transition-all duration-200",
                isActive
                  ? "bg-primary text-primary-foreground shadow-sm"
                  : "text-muted-foreground hover:bg-accent/50 hover:text-foreground",
              ]}
            >
              <Icon className="w-4 h-4" />
              <span class="hidden sm:inline">{label}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
